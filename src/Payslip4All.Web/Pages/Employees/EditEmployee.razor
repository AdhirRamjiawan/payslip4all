@page "/portal/companies/{companyId:guid}/employees/{employeeId:guid}/edit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "CompanyOwner")]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Payslip4All.Application.DTOs.Employee
@using Payslip4All.Application.Interfaces
@inject IEmployeeService EmployeeService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Edit Employee - Payslip4All</PageTitle>

<div class="container mt-4">
    <h2>Edit Employee</h2>

    <LoadingSpinner IsLoading="@_isLoading" />
    <ErrorBanner ErrorMessage="@_errorMessage" OnDismiss="@(() => _errorMessage = null)" />

    @if (!_isLoading && _model != null)
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">First Name *</label>
                    <InputText class="form-control" @bind-Value="_model.FirstName" />
                    <ValidationMessage For="@(() => _model.FirstName)" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Last Name *</label>
                    <InputText class="form-control" @bind-Value="_model.LastName" />
                    <ValidationMessage For="@(() => _model.LastName)" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">ID Number *</label>
                    <InputText class="form-control" @bind-Value="_model.IdNumber" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Employee Number *</label>
                    <InputText class="form-control" @bind-Value="_model.EmployeeNumber" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Start Date</label>
                    <InputDate class="form-control" @bind-Value="_model.StartDate" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Occupation *</label>
                    <InputText class="form-control" @bind-Value="_model.Occupation" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Monthly Gross Salary (R) *</label>
                    <InputNumber class="form-control" @bind-Value="_model.MonthlyGrossSalary" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">UIF Reference</label>
                    <InputText class="form-control" @bind-Value="_model.UifReference" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                @if (_isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Save Changes
            </button>
            <a href="/portal/companies/@CompanyId/employees/@EmployeeId" class="btn btn-secondary ms-2">Cancel</a>
        </EditForm>
    }
</div>

@code {
    [Parameter] public Guid CompanyId { get; set; }
    [Parameter] public Guid EmployeeId { get; set; }

    private FormModel? _model;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var userId = await GetUserIdAsync();
            if (!userId.HasValue) { Nav.NavigateTo("/Portal/Auth/Login"); return; }

            var emp = await EmployeeService.GetEmployeeByIdAsync(EmployeeId, userId.Value);
            if (emp == null) { Nav.NavigateTo($"/portal/companies/{CompanyId}"); return; }

            _model = new FormModel
            {
                FirstName = emp.FirstName, LastName = emp.LastName, IdNumber = emp.IdNumber,
                EmployeeNumber = emp.EmployeeNumber, StartDate = emp.StartDate,
                Occupation = emp.Occupation, UifReference = emp.UifReference,
                MonthlyGrossSalary = emp.MonthlyGrossSalary
            };
        }
        catch { _errorMessage = "Failed to load employee."; }
        finally { _isLoading = false; }
    }

    private async Task HandleSubmit()
    {
        if (_model == null) return;
        _isSaving = true;
        _errorMessage = null;
        try
        {
            var userId = await GetUserIdAsync();
            if (!userId.HasValue) { _errorMessage = "Not authenticated."; return; }

            await EmployeeService.UpdateEmployeeAsync(new UpdateEmployeeCommand
            {
                Id = EmployeeId, UserId = userId.Value,
                FirstName = _model.FirstName, LastName = _model.LastName,
                IdNumber = _model.IdNumber, EmployeeNumber = _model.EmployeeNumber,
                StartDate = _model.StartDate, Occupation = _model.Occupation,
                UifReference = _model.UifReference, MonthlyGrossSalary = _model.MonthlyGrossSalary
            });
            Nav.NavigateTo($"/portal/companies/{CompanyId}/employees/{EmployeeId}");
        }
        catch (ArgumentException ex) { _errorMessage = ex.Message; }
        catch { _errorMessage = "Failed to update employee."; }
        finally { _isSaving = false; }
    }

    private async Task<Guid?> GetUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var str = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(str, out var id) ? id : null;
    }

    public class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required] public string FirstName { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string LastName { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string IdNumber { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string EmployeeNumber { get; set; } = "";
        public DateOnly StartDate { get; set; }
        [System.ComponentModel.DataAnnotations.Required] public string Occupation { get; set; } = "";
        public string? UifReference { get; set; }
        public decimal MonthlyGrossSalary { get; set; }
    }
}
