@page "/portal/wallet"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "CompanyOwner")]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Logging
@using Payslip4All.Application.DTOs.Wallet
@using Payslip4All.Application.Interfaces
@using Payslip4All.Domain.Entities
@using Payslip4All.Domain.Enums
@inject IWalletService WalletService
@inject IWalletTopUpService WalletTopUpService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject ILogger<Wallet> Logger

<PageTitle>Wallet - Payslip4All</PageTitle>

<div class="container mt-4">
    <h2>Wallet</h2>

    <LoadingSpinner IsLoading="@_isLoading" />
    <ErrorBanner ErrorMessage="@_errorMessage" OnDismiss="@(() => _errorMessage = null)" />

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }

    @if (!_isLoading && _wallet != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Current Balance</h5>
                        <p class="display-6 mb-0">R @_wallet.CurrentBalance.ToString("N2")</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Current Payslip Price</h5>
                        <p class="display-6 mb-0">R @_wallet.CurrentPayslipPrice.ToString("N2")</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Add Wallet Credits</h5>
                <p class="text-muted">Card-only payments are collected on an external PayFast hosted page. Payslip4All never stores or displays card details.</p>
                <EditForm Model="_form" OnValidSubmit="HandleTopUpAsync">
                    <DataAnnotationsValidator />
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6">
                            <label class="form-label">Amount (R50 to R1000)</label>
                            <InputNumber class="form-control" @bind-Value="_form.Amount" />
                            <ValidationMessage For="@(() => _form.Amount)" />
                        </div>
                        <div class="col-md-6">
                            <button type="submit" class="btn btn-primary" disabled="@_isSubmitting">
                                @if (_isSubmitting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                Top Up Wallet
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Top-up History</h5>

                @if (_topUpAttempts.Count == 0)
                {
                    <p class="text-muted mb-0">No hosted PayFast card top-ups yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Requested</th>
                                    <th>Confirmed</th>
                                    <th>Abandon after</th>
                                    <th>Result</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var attempt in _topUpAttempts)
                                {
                                    <tr>
                                        <td>@attempt.CreatedAt.ToUniversalTime().ToString("yyyy-MM-dd HH:mm 'UTC'")</td>
                                        <td><span class="badge @GetBadgeClass(attempt.Status)">@attempt.Status</span></td>
                                        <td>@attempt.RequestedAmount.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)</td>
                                        <td>@(attempt.ConfirmedChargedAmount.HasValue ? $"R {attempt.ConfirmedChargedAmount.Value.ToString("N2", System.Globalization.CultureInfo.InvariantCulture)}" : "-")</td>
                                        <td>@(attempt.Status == WalletTopUpAttemptStatus.Pending ? attempt.AbandonAfterUtc.ToUniversalTime().ToString("yyyy-MM-dd HH:mm 'UTC'") : "-")</td>
                                        <td><a href="@($"/portal/wallet/top-ups/{attempt.Id}/return")">View</a></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Recent Activity</h5>

                @if (_wallet.Activities.Count == 0)
                {
                    <p class="text-muted mb-0">No wallet activity yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Amount</th>
                                    <th>Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var activity in _wallet.Activities)
                                {
                                    <tr>
                                        <td>@activity.OccurredAt.ToUniversalTime().ToString("yyyy-MM-dd HH:mm 'UTC'")</td>
                                        <td>@activity.ActivityType</td>
                                        <td>@(string.IsNullOrWhiteSpace(activity.Description) ? "-" : activity.Description)</td>
                                        <td>R @activity.Amount.ToString("N2")</td>
                                        <td>R @activity.BalanceAfterActivity.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private WalletDto? _wallet;
    private IReadOnlyList<WalletTopUpAttemptDto> _topUpAttempts = Array.Empty<WalletTopUpAttemptDto>();
    private FormModel _form = new();
    private bool _isLoading = true;
    private bool _isSubmitting;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadWalletAsync();
    }

    private async Task HandleTopUpAsync()
    {
        _errorMessage = null;
        _successMessage = null;
        _isSubmitting = true;

        try
        {
            var userId = await GetUserIdAsync();
            if (!userId.HasValue)
            {
                Nav.NavigateTo("/Portal/Auth/Login");
                return;
            }

            var startResult = await WalletTopUpService.StartHostedTopUpAsync(new StartWalletTopUpCommand
            {
                UserId = userId.Value,
                RequestedAmount = _form.Amount,
                ProviderKey = "payfast",
                ReturnUrl = $"{Nav.BaseUri.TrimEnd('/')}/portal/wallet/top-ups/return",
                CancelUrl = $"{Nav.BaseUri.TrimEnd('/')}/portal/wallet"
            });

            Nav.NavigateTo(startResult.RedirectUrl, forceLoad: true);
        }
        catch (ArgumentException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogError(ex, "Hosted wallet top-up could not be started.");
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected wallet top-up start failure.");
            _errorMessage = "Payment could not be started";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task LoadWalletAsync()
    {
        try
        {
            var userId = await GetUserIdAsync();
            if (!userId.HasValue)
            {
                Nav.NavigateTo("/Portal/Auth/Login");
                return;
            }

            _wallet = await WalletService.GetWalletAsync(userId.Value);
            _topUpAttempts = await WalletTopUpService.GetHistoryAsync(userId.Value);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load wallet details.");
            _errorMessage = "Wallet details are temporarily unavailable. Please refresh the page or try again shortly.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<Guid?> GetUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var str = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(str, out var id) ? id : null;
    }

    private static string GetBadgeClass(WalletTopUpAttemptStatus status)
        => status switch
        {
            WalletTopUpAttemptStatus.Completed => "bg-success",
            WalletTopUpAttemptStatus.Cancelled => "bg-secondary",
            WalletTopUpAttemptStatus.Expired => "bg-dark",
            WalletTopUpAttemptStatus.Abandoned => "bg-warning text-dark",
            WalletTopUpAttemptStatus.NotConfirmed => "bg-info text-dark",
            _ => "bg-primary"
        };

    public class FormModel
    {
        [System.ComponentModel.DataAnnotations.Range(50, 1000, ErrorMessage = "Amount must be between R50 and R1000.")]
        public decimal Amount { get; set; }
    }
}
