{
  // PERSISTENCE_PROVIDER env var controls the database backend.
  // Valid values: sqlite (default), mysql, dynamodb
  //
  // SQLite (default — no extra config needed):
  //   PERSISTENCE_PROVIDER=sqlite  (or leave unset)
  //
  // MySQL:
  //   PERSISTENCE_PROVIDER=mysql
  //   ConnectionStrings__MySqlConnection=<your connection string>
  //
  // DynamoDB:
  //   PERSISTENCE_PROVIDER=dynamodb
  //   DYNAMODB_REGION=us-east-1                    (required)
  //   DYNAMODB_ENDPOINT=http://localhost:8000       (optional; for DynamoDB Local)
  //   AWS_ACCESS_KEY_ID=<key>                       (optional; falls back to SDK credential chain)
  //   AWS_SECRET_ACCESS_KEY=<secret>                (optional; falls back to SDK credential chain)
  //   DYNAMODB_TABLE_PREFIX=payslip4all             (optional; default: payslip4all)
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=payslip4all.db",
    "MySqlConnection": ""
  },
  "Auth": {
    "Cookie": {
      "ExpireDays": 30
    }
  },
  "BCrypt": {
    "WorkFactor": 12
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/payslip4all-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "buffered": false,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
