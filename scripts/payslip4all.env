# Copy to /etc/payslip4all/payslip4all.env on the EC2 instance.
# Fill in the placeholder values before starting the service.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:8080
PERSISTENCE_PROVIDER=dynamodb
DYNAMODB_REGION=<aws-region>
DYNAMODB_TABLE_PREFIX=payslip4all
DYNAMODB_ENABLE_PITR=true

# Optional: only include these when you use app-config JSON on disk.
# PAYSLIP4ALL_AWS_SECRETS_CONFIG_PATH=/etc/payslip4all/app-config.secrets.json

# Optional hosted payment values if you are not injecting them through another secret source.
# HostedPayments__PayFast__ProviderKey=payfast
# HostedPayments__PayFast__UseSandbox=false
# HostedPayments__PayFast__MerchantId=<merchant-id>
# HostedPayments__PayFast__MerchantKey=<merchant-key>
# HostedPayments__PayFast__Passphrase=<passphrase>
# HostedPayments__PayFast__PublicNotifyUrl=https://payslip4all.co.za/api/payments/payfast/notify
