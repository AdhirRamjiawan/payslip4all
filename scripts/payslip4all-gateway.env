# Copy to /etc/payslip4all/payslip4all-gateway.env on the EC2 instance.
# Fill in the placeholder values before starting the gateway.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:80;https://0.0.0.0:443
REVERSE_PROXY_ENABLED=true
REVERSE_PROXY_PUBLIC_HOST=<public-hostname>
REVERSE_PROXY_UPSTREAM_BASE_URL=http://127.0.0.1:8080
REVERSE_PROXY_ACTIVITY_TIMEOUT_SECONDS=10
Kestrel__Certificates__Default__Path=/etc/payslip4all/certs/payslip4all.pfx
Kestrel__Certificates__Default__Password=<pfx-password>
